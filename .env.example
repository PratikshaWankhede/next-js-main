AUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:3000
# IANA timezone for booking display (lead page + confirmation messages). Default Asia/Kolkata. Use NEXT_PUBLIC_ so the lead page (browser) picks it up.
# NEXT_PUBLIC_BOOKING_DISPLAY_TIMEZONE=Asia/Kolkata
MONGODB_URI=your-mongodb-atlas-connection-string
GOOGLE_GENERATIVE_AI_API_KEY=your-google-generative-ai-api-key

# WhatsApp (Meta Cloud API)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
# Set to true/1 to skip signature verification (local ngrok testing only - do NOT use in production)
WHATSAPP_SKIP_SIGNATURE_VERIFICATION=
WHATSAPP_WEBHOOK_LOGS_ENABLED=

# Instagram (Meta Graph API)
# Often the Page access_token from GET https://graph.facebook.com/v19.0/me/accounts (each data[].access_token).
# Webhook image downloads from Meta CDN (lookaside.fbsbx.com) may require a Page token — set INSTAGRAM_PAGE_ACCESS_TOKEN if IG user tokens fail.
# No quotes around the value. One line only. If Graph returns 190 "Cannot parse access token", check for spaces, line breaks, or extra " characters.
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_VERIFY_TOKEN=
# Facebook Page id linked to the Instagram professional inbox (digits only, not the 178414… Instagram id). Optional if INSTAGRAM_BUSINESS_ACCOUNT_ID is set — we resolve via connected_facebook_page.
# FACEBOOK_PAGE_ID=
# Instagram Business Account id (same as entry.id in webhooks, e.g. 178414…). Skips mis-classifying your own outbound echoes if is_echo is missing; also used to resolve FACEBOOK_PAGE_ID for outbound media.
# INSTAGRAM_BUSINESS_ACCOUNT_ID=
# Optional: explicit Page token for User Profile API (name/username by IGSID). If unset, INSTAGRAM_ACCESS_TOKEN is used.
INSTAGRAM_PAGE_ACCESS_TOKEN=
# FACEBOOK_PAGE_ACCESS_TOKEN=
# Optional Graph API version for profile lookups (default v21.0). Match your /me/accounts version if you prefer, e.g. v19.0
# META_GRAPH_API_VERSION=v19.0
# Verbose server logs for Instagram User Profile enrichment (token source, igsid, Graph errors, saved name). Never logs the token.
# INSTAGRAM_PROFILE_DEBUG=true

# WebSocket broadcast (optional, defaults to http://localhost:3001)
WS_BROADCAST_URL=

#  WebSocket client URL (optional; auto-derived from page protocol in browser)
# For production HTTPS, set to your WSS endpoint, e.g. wss://your-ws-server.example.com
NEXT_PUBLIC_WS_URL=